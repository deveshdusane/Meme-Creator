# Copy to .env.local and fill in.

# Free GIPHY key (browse tabs): https://developers.giphy.com/  → Create App → API
GIPHY_API_KEY=

# Text-to-image works with NO key (Pollinations anonymous flux).

# IMAGE TRANSFORM (redraw an uploaded image per a prompt) — backends in order:
# 1. Gemini — NOTE: Google removed image gen from the free tier (limit 0) as of
#    mid-2026; only works with billing enabled. Falls through automatically.
GEMINI_API_KEY=
# 2. Pollinations Kontext (free quest credits): https://enter.pollinations.ai → Keys
POLLINATIONS_TOKEN=
