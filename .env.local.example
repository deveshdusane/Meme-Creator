# Copy to .env.local and fill in.
# Free GIPHY key: https://developers.giphy.com/  (Create App → API key)
GIPHY_API_KEY=

# --- AI Create ---
# Works with ZERO config: text-to-image falls back to Pollinations.ai (no key).

# IMAGE TRANSFORM (redraw an uploaded image per a prompt, img2img) needs a free
# Pollinations token — register at https://enter.pollinations.ai
# POLLINATIONS_TOKEN=

# Add Cloudflare Workers AI (free tier) for vision analysis of uploads + FLUX gen:
#   dash.cloudflare.com → AI → Workers AI (get Account ID + create an API token)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_TOKEN=
