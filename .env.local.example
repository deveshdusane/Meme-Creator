# Copy to .env.local and fill in.

# Free GIPHY key (browse tabs): https://developers.giphy.com/  → Create App → API
GIPHY_API_KEY=

# Text-to-image works with NO key (Pollinations anonymous flux).
# IMAGE TRANSFORM (redraw an uploaded image per a prompt, img2img) needs a free
# Pollinations API key — register at https://enter.pollinations.ai (Keys → Add Key)
POLLINATIONS_TOKEN=
